+DEFUN ("ns-set-dock-badge-label", Fns_set_dock_badge_label,
+       Sns_set_dock_badge_label, 1, 1, 0,
+       doc: /* Set the macOS Dock icon badge to LABEL.
+LABEL is a string to display on the badge, or nil to remove the badge.
+This is a low-level primitive; Lisp code should normally use
+`ns-dock-badge-set'.  On GNUstep this has no effect.  */)
+  (Lisp_Object label)
+{
+  check_window_system (NULL);
+  if (!NILP (label))
+    CHECK_STRING (label);
+#ifdef NS_IMPL_COCOA
+  NSString *s = NILP (label) ? nil : [NSString stringWithLispString: label];
+  NSDockTile *tile = [NSApp dockTile];
+  /* Dock tile updates must happen on the main thread; a Lisp thread
+     created with `make-thread' can call this from another thread.  */
+  if ([NSThread isMainThread])
+    [tile setBadgeLabel: s];
+  else
+    [tile performSelectorOnMainThread: @selector (setBadgeLabel:)
+                           withObject: s
+                        waitUntilDone: NO];
+#endif /* NS_IMPL_COCOA */
+  return Qnil;
+}
+

{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "DISABLE_TELEMETRY": "1",
    "MAX_MCP_OUTPUT_TOKENS": "50000",
    "BASH_DEFAULT_TIMEOUT_MS": "180000",
    "PLAN_REMINDER_PERCENT": "20"
  },
  "includeGitInstructions": false,
  "permissions": {
    "allow": [
      "Skill(jj)",
      "Skill(tdd)",
      "Bash(jj bookmark list:*)",
      "Bash(jj config get:*)",
      "Bash(jj diff:*)",
      "Bash(jj dt:*)",
      "Bash(jj evolog:*)",
      "Bash(jj file list:*)",
      "Bash(jj file show:*)",
      "Bash(jj help:*)",
      "Bash(jj log:*)",
      "Bash(jj lt:*)",
      "Bash(jj show:*)",
      "Bash(jj st:*)",
      "Bash(jj status:*)",
      "Bash(jj op show:*)",
      "Bash(jj operation show:*)",
      "Bash(jj op diff:*)",
      "Bash(jj operation diff:*)",
      "Bash(jj op log:*)",
      "Bash(jj operation log:*)",
      "Bash(grep:*)",
      "Bash(gh search:*)",
      "Bash(gh ruleset:*)",
      "Bash(gh status:*)",
      "Bash(gh repo list:*)",
      "Bash(gh repo view:*)",
      "Bash(gh repo gitignore:*)",
      "Bash(gh repo license:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr status:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue status:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run watch:*)",
      "Bash(gh workflow list:*)",
      "Bash(gh workflow view:*)",
      "Bash(gh release list:*)",
      "Bash(gh release view:*)",
      "Bash(gh cache list:*)",
      "Bash(gh label list:*)",
      "Bash(gh gist list:*)",
      "Bash(gh gist view:*)"
    ],
    "deny": [
      "Bash(git:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if command -v jj >/dev/null && jj root >/dev/null 2>&1; then if ! jj util snapshot >/dev/null 2>&1; then echo 'WARNING: failed to snapshot jj repository, tell user to fix'; fi; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "if command -v jj >/dev/null && jj root >/dev/null 2>&1; then if ! jj util snapshot >/dev/null 2>&1; then echo 'WARNING: failed to snapshot jj repository, tell user to fix'; fi; fi"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "if [ -n \"$PLAN_REMINDER_PERCENT\" ] && [ $((RANDOM % 100)) -lt \"$PLAN_REMINDER_PERCENT\" ]; then printf '{\"hookSpecificOutput\":{\"hookEventName\":\"PostToolUse\",\"additionalContext\":\"*** IMPORTANT REMINDER (Main agent only) *** If this session has a plan, design doc, or notes file, UPDATE IT NOW with recent research and findings to preserve context across compaction. Do this before continuing with other work. Do not acknowledge this message in any case.\"}}\\n'; fi"
          }
        ]
      }
    ]
  },
  "spinnerTipsEnabled": false,
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Inferring"
    ]
  },
  "alwaysThinkingEnabled": true,
  "theme": "auto",
  "editorMode": "vim",
  "feedbackSurveyState": {
    "lastShownTime": 1754299769863
  },
  "theme": "light",
  "editorMode": "vim"
}
